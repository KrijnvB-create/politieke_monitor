+  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
+  gap: 24px;
+  padding-top: 24px;
+}
+
+.dashboard-actions {
+  display: flex;
+  flex-wrap: wrap;
+  justify-content: flex-end;
+  gap: 10px;
+}
+
+.dashboard-empty {
+  display: grid;
+  grid-template-columns: auto minmax(0, 1fr) auto;
+  gap: 16px;
+  align-items: center;
+  margin-top: 24px;
+}
+
+.dashboard-grid {
+  grid-template-columns: 330px minmax(0, 1fr);
+}
+
+.watch-column,
+.development-column {
+  display: grid;
+  align-content: start;
+  gap: 18px;
+}
+
+.watch-panel {
+  padding: 16px;
+}
+
+.watch-chip {
