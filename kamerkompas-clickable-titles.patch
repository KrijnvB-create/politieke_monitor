+  grid-template-columns: minmax(0, 1fr) minmax(320px, 500px);
+  gap: 20px;
+  align-items: end;
+  padding-bottom: 22px;
+  border-bottom: 1px solid var(--line);
+}
+
+.search-heading h1,
+.dashboard-heading h1 {
+  margin-bottom: 0;
+  font-size: clamp(34px, 5vw, 58px);
+}
+
+.section-heading.compact {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 16px;
+  margin-bottom: 14px;
+}
+
+.section-heading.compact h2,
+.section-heading.compact p {
+  margin-bottom: 0;
+}
+
+.activity-list,
+.dossier-list,
+.saved-list,
+.result-list,
+.watch-list {
+  display: grid;
+  gap: 12px;
+}
+
+.activity-card,
+.dossier-card,
+.saved-row,
+.result-card,
+.watch-panel,
+.profile-card,
+.quiet-panel,
+.empty-state,
+.warning-panel,
+.auth-panel {
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  background: var(--surface);
+  box-shadow: var(--shadow);
+}
+
+.activity-card {
+  display: grid;
+  grid-template-columns: 42px minmax(0, 1fr) auto;
+  gap: 14px;
+  align-items: start;
+  padding: 16px;
+}
+
+.activity-icon {
+  display: grid;
+  width: 42px;
+  height: 42px;
+  place-items: center;
+  border-radius: 8px;
+  background: #e9efe9;
+  color: var(--green);
+}
+
+.activity-body p,
+.dossier-card p {
+  margin-bottom: 0;
+}
+
+.activity-meta {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px;
+  margin-bottom: 6px;
+  color: var(--muted);
+  font-size: 12px;
+  font-weight: 800;
+  text-transform: uppercase;
+}
+
+.dossier-card {
+  display: grid;
+  gap: 14px;
+  padding: 16px;
+}
+
+.search-form {
+  display: grid;
+  grid-template-columns: auto minmax(0, 1fr) auto;
+  gap: 10px;
+  align-items: center;
+  padding: 10px;
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  background: var(--surface);
+  box-shadow: var(--shadow);
+}
+
+.search-form input {
+  width: 100%;
+  min-height: 42px;
+  border: 0;
+  outline: 0;
+  background: transparent;
+  color: var(--ink);
+}
+
+.result-count {
+  display: inline-flex;
+  align-items: center;
+  gap: 8px;
+  margin: 18px 0 22px;
+  padding: 8px 12px;
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  background: #eef3ef;
+  color: var(--green);
+  font-weight: 800;
+}
+
+.result-count span {
+  color: var(--muted);
+  font-size: 14px;
+}
+
+.search-results {
+  display: grid;
+  gap: 28px;
+}
+
+.result-section {
+  padding-bottom: 8px;
+}
+
+.result-card {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) auto;
+  gap: 16px;
+  align-items: start;
+  padding: 16px;
+}
+
+.result-card.compact {
+  box-shadow: none;
+}
+
+.result-main {
+  min-width: 0;
+}
+
+.result-actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px;
+  align-items: center;
+  justify-content: flex-end;
+}
+
+.result-card h3 {
+  margin-bottom: 6px;
+}
+
+.result-title-link {
+  color: var(--navy);
