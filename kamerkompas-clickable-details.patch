+function themeItem(query: string): MonitorItem {
+  const term = compactTerm(query);
+
+  return {
+    kind: "thema",
+    id: term.toLowerCase().replace(/[^a-z0-9]+/gi, "-").replace(/^-|-$/g, "") || term,
+    title: term,
+    eyebrow: "Thema",
+    description: "Volg dit thema in moties, Kamerbrieven, debatten en dossiers.",
+    date: "Doorlopend",
+    meta: { query: term }
+  };
+}
