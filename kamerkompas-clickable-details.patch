-  }
-
-  .ticker-band {
-    grid-template-columns: 1fr;
-  }
-
-  .ticker-band > div {
-    display: grid;
-  }
-
-  .ticker-band span {
-    max-width: 100%;
-  }
-}
+:root {
+  --paper: #f5f1e8;
+  --surface: #fffdf8;
+  --ink: #171615;
+  --muted: #655f56;
+  --line: #d7cfc0;
+  --navy: #17324d;
+  --red: #a33b2f;
+  --green: #2f6f5e;
+  --gold: #b0832f;
+  --shadow: 0 16px 40px rgba(31, 29, 26, 0.08);
+}
+
+* {
+  box-sizing: border-box;
+}
+
+html {
+  background: var(--paper);
+  color: var(--ink);
+}
+
+body {
+  min-height: 100vh;
+  margin: 0;
+  font-family:
+    Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
+    sans-serif;
+  letter-spacing: 0;
+}
+
+a {
+  color: inherit;
+  text-decoration: none;
+}
+
+button,
+input {
+  font: inherit;
+}
+
+input {
+  min-width: 0;
+}
+
+.site-header {
+  position: sticky;
+  top: 0;
+  z-index: 20;
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 24px;
+  padding: 14px clamp(18px, 4vw, 48px);
+  background: rgba(245, 241, 232, 0.92);
+  border-bottom: 1px solid var(--line);
+  backdrop-filter: blur(14px);
+}
+
+.brand {
+  display: inline-flex;
+  align-items: center;
+  gap: 10px;
+  color: var(--navy);
+  font-weight: 800;
+}
+
+.brand span {
+  display: grid;
+  line-height: 1.05;
+}
+
+.brand small {
+  margin-top: 2px;
+  color: var(--muted);
+  font-size: 11px;
+  font-weight: 600;
+  text-transform: uppercase;
+}
+
+.main-nav {
+  display: flex;
+  align-items: center;
+  flex-wrap: wrap;
+  justify-content: flex-end;
+  gap: 8px;
+}
+
+.main-nav a,
+.icon-button {
+  display: inline-flex;
+  min-height: 38px;
+  align-items: center;
+  gap: 7px;
+  padding: 8px 10px;
+  border: 1px solid transparent;
+  background: transparent;
+  color: var(--muted);
+  cursor: pointer;
+  font-size: 14px;
+  font-weight: 700;
+}
+
+.main-nav a:hover,
+.icon-button:hover {
+  color: var(--ink);
+  border-color: var(--line);
+}
+
+.nav-cta {
+  background: var(--navy) !important;
+  color: white !important;
+}
+
+.dashboard,
+.page-shell,
+.auth-page {
+  width: min(1180px, calc(100% - 36px));
+  margin: 0 auto;
+}
+
+.dashboard {
+  padding: 28px 0 54px;
+}
+
+.status-band {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) minmax(310px, 460px);
+  gap: 24px;
+  align-items: end;
+  padding: 34px 0 28px;
+  border-bottom: 1px solid var(--line);
+}
+
+.eyebrow {
+  margin: 0 0 8px;
+  color: var(--red);
+  font-size: 12px;
+  font-weight: 900;
+  text-transform: uppercase;
+}
+
+h1,
+h2,
+h3,
+p {
+  margin-top: 0;
+}
+
+h1 {
+  max-width: 760px;
+  margin-bottom: 12px;
+  font-size: clamp(34px, 6vw, 70px);
+  line-height: 0.98;
+}
+
+h2 {
+  margin-bottom: 8px;
+  font-size: 24px;
+  line-height: 1.15;
+}
+
+h3 {
+  margin-bottom: 7px;
+  font-size: 17px;
+  line-height: 1.3;
+}
+
+p {
+  color: var(--muted);
+  line-height: 1.6;
+}
+
+.status-band p {
+  max-width: 620px;
+  margin-bottom: 0;
+  font-size: 18px;
+}
+
+.status-metrics {
+  display: grid;
+  grid-template-columns: 1fr 1fr;
+  gap: 10px;
+}
+
+.status-metrics div,
+.status-metrics a {
+  display: grid;
+  min-height: 92px;
+  align-content: space-between;
+  gap: 8px;
+  padding: 14px;
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  background: var(--surface);
+}
+
+.status-metrics a {
+  grid-column: 1 / -1;
+  min-height: 54px;
+  grid-template-columns: auto 1fr;
+  align-items: center;
+  align-content: center;
+  color: var(--navy);
+  font-weight: 800;
+}
+
+.status-metrics span {
+  color: var(--muted);
+  font-size: 12px;
+  font-weight: 800;
+  text-transform: uppercase;
+}
+
+.status-metrics strong {
+  font-size: 18px;
+}
+
+.content-grid {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) 340px;
+  gap: 28px;
+  padding-top: 28px;
+}
+
+.section-heading {
+  margin-bottom: 18px;
+}
+
+.search-heading,
+.dashboard-heading {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) minmax(320px, 500px);
+  gap: 20px;
+  align-items: end;
+  padding-bottom: 22px;
+  border-bottom: 1px solid var(--line);
+}
+
+.search-heading h1,
+.dashboard-heading h1 {
+  margin-bottom: 0;
+  font-size: clamp(34px, 5vw, 58px);
+}
+
+.section-heading.compact {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 16px;
+  margin-bottom: 14px;
+}
+
+.section-heading.compact h2,
+.section-heading.compact p {
+  margin-bottom: 0;
+}
+
+.activity-list,
+.dossier-list,
+.saved-list,
+.result-list,
+.watch-list {
+  display: grid;
+  gap: 12px;
+}
+
+.activity-card,
+.dossier-card,
+.saved-row,
+.result-card,
+.watch-panel,
+.profile-card,
+.quiet-panel,
+.empty-state,
+.warning-panel,
+.auth-panel {
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  background: var(--surface);
+  box-shadow: var(--shadow);
+}
+
+.activity-card {
+  display: grid;
+  grid-template-columns: 42px minmax(0, 1fr) auto;
+  gap: 14px;
+  align-items: start;
+  padding: 16px;
+}
+
+.activity-icon {
+  display: grid;
+  width: 42px;
+  height: 42px;
+  place-items: center;
+  border-radius: 8px;
+  background: #e9efe9;
+  color: var(--green);
+}
+
+.activity-body p,
+.dossier-card p {
+  margin-bottom: 0;
+}
+
+.activity-meta {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px;
+  margin-bottom: 6px;
+  color: var(--muted);
+  font-size: 12px;
+  font-weight: 800;
+  text-transform: uppercase;
+}
+
+.dossier-card {
+  display: grid;
+  gap: 14px;
+  padding: 16px;
+}
+
+.search-form {
+  display: grid;
+  grid-template-columns: auto minmax(0, 1fr) auto;
+  gap: 10px;
+  align-items: center;
+  padding: 10px;
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  background: var(--surface);
+  box-shadow: var(--shadow);
+}
+
+.search-form input {
+  width: 100%;
+  min-height: 42px;
+  border: 0;
+  outline: 0;
+  background: transparent;
+  color: var(--ink);
+}
+
+.result-count {
+  display: inline-flex;
+  align-items: center;
+  gap: 8px;
+  margin: 18px 0 22px;
+  padding: 8px 12px;
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  background: #eef3ef;
+  color: var(--green);
+  font-weight: 800;
+}
+
+.result-count span {
+  color: var(--muted);
+  font-size: 14px;
+}
+
+.search-results {
+  display: grid;
+  gap: 28px;
+}
+
+.result-section {
+  padding-bottom: 8px;
+}
+
+.result-card {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) auto;
+  gap: 16px;
+  align-items: start;
+  padding: 16px;
+}
+
+.result-card.compact {
+  box-shadow: none;
+}
+
+.result-main {
+  min-width: 0;
+}
+
+.result-actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px;
+  align-items: center;
+  justify-content: flex-end;
+}
+
+.result-card h3 {
+  margin-bottom: 6px;
+}
+
+.result-card p {
+  margin-bottom: 0;
+}
+
+.result-meta {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px;
+  margin-bottom: 8px;
+  color: var(--muted);
+  font-size: 12px;
+  font-weight: 850;
+  text-transform: uppercase;
+}
+
+.result-meta span {
+  display: inline-flex;
+  align-items: center;
+  gap: 4px;
+}
+
+.match-label {
+  margin-top: 8px !important;
+  color: var(--green);
+  font-size: 13px;
+  font-weight: 800;
+}
+
+.debate-grid,
+.dashboard-grid {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
+  gap: 24px;
+  padding-top: 24px;
+}
+
+.dashboard-actions {
+  display: flex;
+  flex-wrap: wrap;
+  justify-content: flex-end;
+  gap: 10px;
+}
+
+.dashboard-empty {
+  display: grid;
+  grid-template-columns: auto minmax(0, 1fr) auto;
+  gap: 16px;
+  align-items: center;
+  margin-top: 24px;
+}
+
+.dashboard-grid {
+  grid-template-columns: 330px minmax(0, 1fr);
+}
+
+.watch-column,
+.development-column {
+  display: grid;
+  align-content: start;
+  gap: 18px;
+}
+
+.watch-panel {
+  padding: 16px;
+}
+
+.watch-chip {
+  display: grid;
+  gap: 3px;
+  padding: 10px;
+  border: 1px solid var(--line);
+  border-radius: 8px;
+  background: #fbf7ed;
+}
+
+.watch-chip span,
+.quiet-text {
+  color: var(--muted);
+  font-size: 12px;
+  font-weight: 850;
+  text-transform: uppercase;
+}
+
+.watch-chip strong {
+  overflow-wrap: anywhere;
+}
+
+.section-heading.stacked {
+  margin-top: 22px;
+}
+
+.save-button,
+.primary-button,
+.secondary-button {
+  display: inline-flex;
+  min-height: 40px;
+  align-items: center;
+  justify-content: center;
+  gap: 8px;
+  padding: 9px 12px;
+  border-radius: 8px;
+  cursor: pointer;
+  font-weight: 850;
+}
+
+.save-button {
+  min-width: 132px;
+  border: 1px solid #c7bda9;
+  background: #fbf7ed;
+  color: var(--navy);
+}
+
+.save-button:hover {
+  border-color: var(--gold);
+}
+
+.save-button:disabled {
+  cursor: wait;
+  opacity: 0.7;
+}
+
+.primary-button {
+  border: 1px solid var(--navy);
+  background: var(--navy);
+  color: white;
+}
+
+.secondary-button {
+  border: 1px solid var(--line);
+  background: var(--surface);
+  color: var(--ink);
+}
+
+.inline-flex {
+  width: fit-content;
+}
+
+.warning-panel {
+  display: flex;
+  gap: 12px;
+  padding: 16px;
+  color: var(--red);
+}
+
+.warning-panel p {
+  margin-bottom: 0;
+}
+
+.auth-page {
+  display: grid;
+  min-height: calc(100vh - 76px);
+  place-items: center;
+  padding: 42px 0;
+}
+
+.auth-panel {
+  width: min(560px, 100%);
+  padding: 26px;
+}
+
+.auth-panel h1 {
+  font-size: clamp(30px, 5vw, 48px);
+}
+
+.auth-actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 10px;
+  margin: 22px 0 16px;
+}
+
+.text-link {
+  color: var(--navy);
+  font-weight: 800;
+}
+
+.page-shell {
+  padding: 34px 0 54px;
+}
+
+.account-grid {
+  display: grid;
+  grid-template-columns: minmax(0, 420px) minmax(0, 1fr);
+  gap: 18px;
+}
+
+.profile-card,
+.quiet-panel,
+.empty-state {
+  padding: 18px;
+}
+
+.empty-state.small {
+  box-shadow: none;
+}
+
+.profile-card {
+  display: flex;
+  gap: 14px;
+  align-items: center;
+}
+
+.avatar {
+  display: grid;
+  width: 62px;
+  height: 62px;
+  place-items: center;
+  overflow: hidden;
+  border-radius: 50%;
