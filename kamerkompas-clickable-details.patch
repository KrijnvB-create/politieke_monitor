+
+function dateWindow(daysAhead: number) {
+  const start = new Date();
+  start.setHours(0, 0, 0, 0);
+  const end = new Date(start);
+  end.setDate(end.getDate() + daysAhead);
+
+  return {
+    start: start.toISOString(),
+    end: end.toISOString()
+  };
+}
