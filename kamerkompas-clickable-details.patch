-  }
-
-  h1 {
-    font-size: 38px;
-  }
-
-  .status-band {
-    padding-top: 18px;
-  }
-
-  .saved-row {
-    display: grid;
-  }
-
-  .search-form {
-    grid-template-columns: auto minmax(0, 1fr);
-  }
-
-  .search-form button {
