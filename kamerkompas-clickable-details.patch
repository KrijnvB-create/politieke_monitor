-function dedupeItems(items: MonitorItem[]) {
-  const seen = new Set<string>();
-  const unique: MonitorItem[] = [];
-
-  items.forEach((item) => {
-    const key = `${item.kind}:${item.id}`;
-    if (!seen.has(key)) {
-      seen.add(key);
-      unique.push(item);
-    }
-  });
-
-  return unique;
-}
