+    safeOne(tkOne<TkCase>("Zaak", id)),
+    safeOne(tkOne<TkDossier>("Kamerstukdossier", id))
+  ]);
+
+  if (zaak) {
+    return caseToItem(zaak, zaak.Soort === "Motie" ? "motie" : "dossier");
+  }
+
+  return dossier ? dossierToItem(dossier) : null;
+}
