-  grid-template-columns: 360px minmax(0, 1fr);
-  gap: 22px;
-  padding-top: 24px;
-}
-
-.faction-grid {
-  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
-}
-
-.faction-card {
